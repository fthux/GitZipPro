{
  "manifest_version": 3,
  "name": "GitZip Pro",
  "version": "1.1.2",
  "default_locale": "en",
  "description": "GitZip for GitHub, but Pro.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gitzippro@fthux.com",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "downloads",
    "notifications",
    "contextMenus",
    "identity"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "host_permissions": [
    "https://github.com/*",
    "https://gitzip-pro-worker.fthux.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": [
        "constants.js",
        "i18n.js",
        "jszip.min.js",
        "downloader.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["jszip.min.js", "constants.js", "i18n.js", "locales/*"],
      "matches": ["https://github.com/*"]
    }
  ]
}
